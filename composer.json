{
	"name": "projectsaturnstudios/rpi-theme",
	"description": "vue3 laravel-installer movable-type theme",
	"type": "library",
	"version": "1.0.0",
	"license": "MIT",
	"require": {
        "php": "^8.3",
        "projectsaturnstudios/laravel-design-patterns": "^0.1.0"
    },
	"autoload": {
		"psr-4": {
			"ProjectSaturnStudios\\Themes\\RPiTheme\\": "src"
		}
    },
	"minimum-stability": "stable",
    "extra": {
        "laravel": {
            "providers": [
                "ProjectSaturnStudios\\Themes\\RPiTheme\\Providers\\RPiThemeServiceProvider"
            ],
            "aliases": {}
        }
    }
}
